<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ═══════════════════════════════════════════════════════════════
  LaunchAgent: com.kalix.ollama-tunnel
  ═══════════════════════════════════════════════════════════════

  Runs start-tunnel.sh at user login and keeps it alive.

  Install:   bash install-autostart.sh
  Uninstall: bash uninstall-autostart.sh

  Manual control:
    launchctl load   ~/Library/LaunchAgents/com.kalix.ollama-tunnel.plist
    launchctl unload ~/Library/LaunchAgents/com.kalix.ollama-tunnel.plist
    launchctl start  com.kalix.ollama-tunnel
    launchctl stop   com.kalix.ollama-tunnel
  ═══════════════════════════════════════════════════════════════
-->
<plist version="1.0">
<dict>
    <!-- Unique label for this agent -->
    <key>Label</key>
    <string>com.kalix.ollama-tunnel</string>

    <!-- Command to run — path is substituted by install-autostart.sh -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>SCRIPT_PATH_PLACEHOLDER</string>
    </array>

    <!-- Start at login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart automatically if the process exits -->
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 10s before restarting after a crash -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Stdout / Stderr (in addition to the script's own log) -->
    <key>StandardOutPath</key>
    <string>LOG_DIR_PLACEHOLDER/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>LOG_DIR_PLACEHOLDER/launchd-stderr.log</string>

    <!-- Inherit the user's PATH so nginx/cloudflared are found -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>HOME_PLACEHOLDER</string>
    </dict>
</dict>
</plist>
